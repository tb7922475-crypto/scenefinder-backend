# PostgreSQL connection string (Railway / Heroku style)
DATABASE_URL=postgresql://user:password@host:port/database

# Google Gemini API key (used for text and image embeddings)
GEMINI_API_KEY=your_api_key_here

# Server port (Railway sets this automatically)
PORT=3000

# Node environment
NODE_ENV=production

# Optional: legacy Google API key alias (GEMINI_API_KEY takes precedence)
# GOOGLE_API_KEY=your_api_key_here

# Optional: background indexer poll interval in milliseconds (default: 30000)
# INDEXER_POLL_INTERVAL_MS=30000

# Optional: seconds between extracted frames during indexing (default: 1)
# INDEXER_FRAME_INTERVAL=1
